<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <ImageView
        android:id="@+id/item_album_cover_iv"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/img_album_exp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 앨범 제목 -->
    <TextView
        android:id="@+id/item_album_title_tv"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="GREAT!"
        android:textSize="16sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        android:textColor="@color/black"
        android:layout_marginStart="12dp"
        app:layout_constraintTop_toTopOf="@id/item_album_cover_iv"
        app:layout_constraintStart_toEndOf="@id/item_album_cover_iv"
        app:layout_constraintEnd_toStartOf="@id/item_album_play_btn" />

    <!-- 아티스트 + 날짜/정보 -->
    <TextView
        android:id="@+id/item_album_info_tv"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="모모랜드 (MOMOLAND)\n2021.03.25 | 정규 | 댄스 팝"
        android:textSize="13sp"
        android:textColor="@color/gray_color"
        android:lineSpacingExtra="2dp"
        android:layout_marginTop="2dp"
        app:layout_constraintTop_toBottomOf="@id/item_album_title_tv"
        app:layout_constraintStart_toStartOf="@id/item_album_title_tv"
        app:layout_constraintEnd_toEndOf="@id/item_album_title_tv" />

    <!-- 재생 버튼 -->
    <ImageView
        android:id="@+id/item_album_play_btn"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="4dp"
        android:src="@drawable/btn_miniplayer_play"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/item_album_more_btn" />

    <!-- more 버튼 -->
    <ImageView
        android:id="@+id/item_album_more_btn"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/btn_player_more"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>