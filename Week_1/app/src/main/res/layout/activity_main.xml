<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">


    <!-- 제목 텍스트 -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="\n오늘 하루는 어땠나요?\n감정우표를 선택해주세요"
        android:textSize="24sp"
        android:fontFamily="cursive"
        android:textAlignment="center"
        android:textColor="@android:color/black"
        android:gravity="center"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="\n선택한 감정우표를 기반으로 맞춤형 질문이 배달됩니다"
        android:textSize="14sp"
        android:fontFamily="serif"
        android:textColor="@android:color/darker_gray"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <!--버튼-->

    <ImageButton
        android:id="@+id/group_462"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginTop="48dp"
        android:background="@null"
        android:src="@drawable/group_462"
        android:contentDescription="행복 스티커"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.501"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title" />


    <TextView
        android:id="@+id/tv_happy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="76dp"
        android:gravity="center"
        android:text="더없이 행복한 하루였어요"
        android:textColor="@android:color/black"
        android:textSize="16sp"
        android:fontFamily="serif"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/group_462" />

    <ImageButton
        android:id="@+id/group_462_1"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/group_462_1"
        android:contentDescription="들뜬 스티커"
        android:background="@null"
        app:layout_constraintTop_toBottomOf="@id/group_462"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <TextView
        android:id="@+id/tv_excited"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="76dp"
        android:gravity="center"
        android:text="들뜨고 흥분돼요"
        android:textColor="@android:color/black"
        android:textSize="16sp"
        android:fontFamily="serif"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/group_462_1" />

    <ImageButton
        android:id="@+id/group_462_2"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:background="@null"
        android:src="@drawable/group_462_2"
        android:contentDescription="평범한 스티커"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.501"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/group_462_1"
        app:layout_constraintVertical_bias="0.0" />

    <TextView
        android:id="@+id/tv_normal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="76dp"
        android:gravity="center"
        android:text="평범한 하루였어요"
        android:textColor="@android:color/black"
        android:textSize="16sp"
        android:fontFamily="serif"
        app:layout_constraintBottom_toBottomOf="@+id/tv_anxious"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.501"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/group_462_2"
        app:layout_constraintVertical_bias="0.0" />

    <ImageButton
        android:id="@+id/group_462__1_"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/group_462__1_"
        android:contentDescription="불안 스티커"
        android:background="@null"
        app:layout_constraintTop_toBottomOf="@id/group_462_2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tv_anxious"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="76dp"
        android:gravity="center"
        android:text="생각이 많아지고 불안해요"
        android:textColor="@android:color/black"
        android:textSize="16sp"
        android:fontFamily="serif"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.501"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/group_462__1_" />

    <ImageButton
        android:id="@+id/group_462__2_"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/group_462__2_"
        android:contentDescription="화 스티커"
        android:background="@null"
        app:layout_constraintTop_toBottomOf="@id/group_462__1_"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tv_angry"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="76dp"
        android:gravity="center"
        android:text="부글부글 화가 나요"
        android:textColor="@android:color/black"
        android:textSize="16sp"
        android:fontFamily="serif"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/group_462__2_" />


</androidx.constraintlayout.widget.ConstraintLayout>
